    s_QuestTitle: The Dawn Sword
    s_QuestDescription: Get iron from the northern mines and deliver it to Aldric.
    s_QuestObjectives:
    - s_OGuid: 7206c287-af99-4297-b05d-c0b25e31e0fa
      s_ObjectiveDescription: Get iron
      s_RequiredCompletedState: 1
