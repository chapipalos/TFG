    replies: []
    questRequirements: []
  - guid: 14717d5c-6c40-40e5-b603-c5f9cdd5cba7
    title: Quest rechazada
    dialogue: "Lo entiendo. Si cambias de opini\xF3n, ya sabes d\xF3nde encontrarme."
