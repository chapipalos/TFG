    s_NGuid: 3ed8e42a-c526-4962-928d-567bc32055d7
    s_NodeTitle: Quest accepted
    s_Dialogue: Excellent. The mines are north. When you have the iron, come back
      here.
    s_NodePosition: {x: 660, y: -150}
    s_ActorGuid: 16494242-e9fe-456d-b498-da381b3a4129
    s_QuestGuid: 
    s_ObjectiveRequirements: []
