      s_ObjectiveDescription: Deliver iron to Aldric
      s_RequiredCompletedState: 1
  s_Nodes:
  - s_ConversationGuid: e10bafe8-0378-4b6a-b064-061512bc72bd
    s_NGuid: ab4d7b4d-2652-452f-bbc4-c9f6c41f20e3
    s_NodeTitle: Intro
    s_Dialogue: Welcome to my forge, traveler! What can I do for you?
    s_NodePosition: {x: 100, y: 300}
    s_ActorGuid: 16494242-e9fe-456d-b498-da381b3a4129
    s_QuestGuid: 
    s_ObjectiveRequirements: []
    s_QuestActions: []
    s_Replies: []
    s_Effects: []
    s_QuestRequirements: []
  - s_ConversationGuid: e10bafe8-0378-4b6a-b064-061512bc72bd
    s_NGuid: 1f5ca8ca-da55-4f59-a4ff-3e4bd7d30607
    s_NodeTitle: Quest offer
    s_Dialogue: I've been looking for someone with guts. I need iron from the Northern
      Mines. Are you interested?
    s_NodePosition: {x: 380, y: -60}
    s_ActorGuid: 16494242-e9fe-456d-b498-da381b3a4129
    s_QuestGuid: 
    s_ObjectiveRequirements: []
    s_QuestActions: []
    s_Replies:
    - s_RGuid: e8f2b26e-3d7d-48bd-a641-30f809d27cdf
      s_ReplyText: I accept. What do I need to do?
    - s_RGuid: f3d6f689-9300-41ff-8f9b-d52e9d67bef9
      s_ReplyText: Not a good time for me.
    s_Effects: []
    s_QuestRequirements:
    - s_QuestGuid: 1374e3af-23a2-4dc9-8173-6427aeb78081
      s_RequiredStatus: 0
