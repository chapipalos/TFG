  - guid: 2d57a0b0-40aa-4b06-88a1-8a33b18bb30c
    title: Intro
    dialogue: "\xA1Bienvenido a mi forja, viajero! \xBFQu\xE9 puedo hacer por ti?"
    position: {x: -95.2, y: 274.40002}
    actorGuid: ca1b5fb4-cfc5-4604-a03f-10dcdd14a42e
    questGuid: 
    conditions: []
    questActions: []
    replies: []
    questRequirements: []
  - guid: a034404f-d82c-4ebf-bce2-bc12c9d1ee30
    title: Oferta de quest
    dialogue: "Llevo semanas buscando a alguien con agallas. Necesito hierro de las
      Minas del Norte. \xBFTe interesa?"
    position: {x: 332.8, y: -57.6}
    actorGuid: ca1b5fb4-cfc5-4604-a03f-10dcdd14a42e
    questGuid: 
    conditions: []
    questActions: []
    replies:
    - guid: 2471ea15-ec09-4eb2-9ae2-0a9cc0fcb00f
      text: "Acepto. \xBFQu\xE9 tengo que hacer?"
    - guid: eaa33749-3844-490c-ad35-fc8024a0fc7f
      text: No es un buen momento.
    questRequirements:
    - questGuid: c266e66f-6f32-4d2f-9235-80c91248acdd
      requiredStatus: 0
  - guid: 60a38769-00a5-4f6e-8f46-2cb83037f064
    title: Quest aceptada
    dialogue: "Excelente. Las minas est\xE1n al norte. Cuando tengas el hierro, vuelve
      aqu\xED."
    position: {x: 660, y: -307.2}
    actorGuid: ca1b5fb4-cfc5-4604-a03f-10dcdd14a42e
    questGuid: c266e66f-6f32-4d2f-9235-80c91248acdd
